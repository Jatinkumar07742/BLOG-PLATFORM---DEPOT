<%- include('../partials/header') %>

<div class="form-container">
  <h1>Edit post</h1>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form action="/posts/<%= post._id %>?_method=PUT" method="POST" class="post-form">
    <label for="title">Title</label>
    <input type="text" id="title" name="title" value="<%= post.title %>" required maxlength="150" />

    <label for="coverImage">Cover Image URL (optional)</label>
    <input type="text" id="coverImage" name="coverImage" value="<%= post.coverImage %>" />

    <label for="content">Content</label>
    <textarea id="content" name="content" rows="14" required><%= post.content %></textarea>

    <button type="submit" class="btn-primary">Save Changes</button>
  </form>
</div>

<%- include('../partials/footer') %>
