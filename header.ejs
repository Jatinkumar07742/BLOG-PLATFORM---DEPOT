<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'BlogSpace' %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <nav class="navbar">
    <div class="navbar-inner">
      <a href="/" class="brand">BlogSpace</a>
      <div class="nav-links">
        <a href="/">Home</a>
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <a href="/posts/new">Write</a>
          <a href="/dashboard">Dashboard</a>
          <span class="nav-user">Hi, <%= currentUser.username %></span>
          <form action="/auth/logout" method="POST" class="inline-form">
            <button type="submit" class="link-button">Logout</button>
          </form>
        <% } else { %>
          <a href="/auth/login">Login</a>
          <a href="/auth/register" class="btn-nav">Sign Up</a>
        <% } %>
      </div>
    </div>
  </nav>
  <main class="container">
